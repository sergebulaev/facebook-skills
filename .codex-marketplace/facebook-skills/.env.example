# -----------------------------------------------------------------
# All variables below are OPTIONAL.
# The skills work in draft-only mode with nothing set.
# Add a PUBLORA_API_KEY to enable auto-posting Facebook Page posts.
# -----------------------------------------------------------------

# Publora API key - sign up free at https://app.publora.com/signup
PUBLORA_API_KEY=sk_your_key_here

# Facebook Page platform connection ID (format: facebook-112233445566)
# Find this in the Publora dashboard: Channels then your Facebook Page.
# Copy the whole thing including the facebook- prefix.
# Each Page you manage has its own facebook-<pageId>.
FACEBOOK_PLATFORM_ID=facebook-your_page_id_here

# -----------------------------------------------------------------
# Apify token (optional) - if you later wire a Facebook post-reading
# actor, the read-side skills can fetch Page post text instead of
# asking you to paste it. Without a token, fb-hook-extractor and
# fb-engagement-drafter fall back to asking you to paste the post.
#
# Sign up: https://console.apify.com/sign-up
# Token:   https://console.apify.com/settings/integrations
# -----------------------------------------------------------------
APIFY_TOKEN=apify_api_your_token_here

# -----------------------------------------------------------------
# Advanced (Tier 2): if you've built your own poster with Claude Code or Codex
# (e.g. on the Facebook Graph API), set this to the command the skills invoke
# on approval. Leave unset unless you actually have a custom poster working.
# -----------------------------------------------------------------
# FB_SKILLS_CUSTOM_POSTER=python /path/to/my-poster.py
